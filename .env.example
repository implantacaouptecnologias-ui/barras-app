COSMOS_TOKEN=MIQWO7f3C8Y2feLI185fBg

# =============================================
# GOOGLE SHEETS - Service Account
# =============================================
# Cole o JSON completo da Service Account entre aspas simples
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}'

# =============================================
# GOOGLE SHEETS REGISTRY (auto-provisionamento)
# =============================================
# ID da planilha MESTRA onde os clientes são registrados.
# Quando configurado, qualquer slug válido na URL criará automaticamente
# uma planilha no Google Drive para aquele cliente.
#
# Como obter:
#   1. Crie manualmente uma planilha no Google Sheets
#   2. Compartilhe com a Service Account (permissão Editor)
#   3. Copie o ID da URL e cole abaixo
REGISTRY_SPREADSHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# (Opcional) ID da pasta no Google Drive onde as planilhas dos clientes serão criadas.
# Se não informado, as planilhas são criadas na raiz do Drive da Service Account.
# DRIVE_FOLDER_ID=1A2B3C4D5E6F7G8H9I0J

# =============================================
# MAPEAMENTO ESTÁTICO (opcional, modo legado)
# Só necessário se NÃO usar REGISTRY_SPREADSHEET_ID
# =============================================
# CLIENT_SHEETS_MAP='{"clienteX":"spreadsheetId1","clienteY":"spreadsheetId2"}'

# =============================================
# CONFIGURAÇÕES DA PLANILHA
# Nome da aba onde os dados serão gravados
# =============================================
SHEET_TAB_NAME=Cadastros

# =============================================
# NEXT.JS / APP
# =============================================
NEXT_PUBLIC_APP_NAME=BarrasApp
